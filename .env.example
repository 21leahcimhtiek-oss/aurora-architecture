# Aurora Rayes Architecture Environment Variables
# Copy this file to .env and fill in local or deployment-specific values.

# App
NEXT_PUBLIC_APP_URL=https://auroramarket.org/aurora-architecture
NODE_ENV=development

# Payments are disabled by default. Use deployment secrets for live values only.
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY

# Database
DATABASE_URL=REPLACE_WITH_DATABASE_URL

# OpenAI / AI
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
