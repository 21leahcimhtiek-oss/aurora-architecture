{
  "version": "1.0.0",
  "repos": [
    {
      "name": "aurora-architecture",
      "path": ".",
      "tags": ["docs", "architecture"]
    }
  ],
  "integrations": {
    "networkSolutions": {
      "command": "node scripts/network-solutions.js",
      "accountEnvVar": "NETWORK_SOLUTIONS_ACCOUNT",
      "siteEnvVar": "NETWORK_SOLUTIONS_SITE",
      "requiredEnvVars": [
        "NETWORK_SOLUTIONS_ACCOUNT",
        "NETWORK_SOLUTIONS_API_KEY"
      ]
    },
    "wordpress": {
      "command": "node scripts/wordpress.js",
      "siteEnvVar": "WORDPRESS_SITE_URL",
      "accountEnvVar": "WORDPRESS_USERNAME",
      "requiredEnvVars": [
        "WORDPRESS_SITE_URL",
        "WORDPRESS_USERNAME",
        "WORDPRESS_APP_PASSWORD"
      ]
    },
    "copilot": {
      "requiredEnvVars": []
    }
  }
}
